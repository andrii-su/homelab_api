# Copy to .env and fill in. NEVER commit .env (public repo).

# Address the API binds to. Inside Docker keep 0.0.0.0; expose via gateway only.
BIND_ADDR=0.0.0.0:8087

# Bearer token required for all control endpoints. Generate a strong one:
#   openssl rand -hex 32
# Required — the server refuses to start without it.
API_TOKEN=

# Optional: downstream push target the /api/notify relay forwards to.
# e.g. ntfy: https://ntfy.sh/your-topic  | Slack webhook | custom APNs proxy
WEBHOOK_URL=

# CORS. "*" for dev; lock to the app origin / gateway domain in prod.
CORS_ORIGINS=*

# Homelab repo root (compose files + .env) for /api/stacks actions.
# In the container this is /homelab; on the host point REPO_ROOT_HOST at the
# repo. DOCKER_GID = GID of the docker socket so the non-root user can use it
# (stat -f %g /var/run/docker.sock on macOS, stat -c %g on Linux).
REPO_ROOT=/homelab
REPO_ROOT_HOST=../homelab
DOCKER_GID=0

# Log level: error|warn|info|debug|trace  (or full RUST_LOG syntax)
RUST_LOG=info
